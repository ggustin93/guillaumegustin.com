# Cloudflare Pages headers — cache policy by path.
#
# IMPORTANT: Cloudflare Pages APPENDS every matching rule's headers (it does
# not override). A broad `/*` Cache-Control rule therefore merges into and
# corrupts the asset rules (e.g. `immutable, no-store` on the same response).
# So we ONLY scope long-cache rules to content-hashed asset directories and
# leave HTML to the Pages default (revalidated each request; edge cache is
# purged on every deploy, so HTML is always fresh).

# Security headers for all responses.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

/.well-known/api-catalog
  Content-Type: application/linkset+json; charset=utf-8

/.well-known/agent-skills/index.json
  Content-Type: application/json; charset=utf-8

/.well-known/mcp/server-card.json
  Content-Type: application/json; charset=utf-8

/openapi.json
  Content-Type: application/openapi+json; charset=utf-8

/auth.md
  Content-Type: text/markdown; charset=utf-8

/llms.txt
  Content-Type: text/markdown; charset=utf-8

# Astro emits content-hashed filenames here — safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Static media that is not content-hashed — moderate cache.
/img/*
  Cache-Control: public, max-age=2592000
