<section class="section section--border-bottom tech-stack" id="tech-stack" aria-labelledby="tech-stack-heading">
  <div class="container-site reveal">
    <SectionLabel index={index} label={label} />
    <h2 id="tech-stack-heading" class="tech-stack__heading">{description}</h2>
    <ul class="tech-stack__icons">
      {
        techs.map((tech) => (
          <li class="tech-item">
            <svg role="img" viewBox={tech.viewBox ?? '0 0 24 24'} xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" aria-hidden="true">
              <path d={tech.path} fill-rule={tech.viewBox ? 'evenodd' : undefined} clip-rule={tech.viewBox ? 'evenodd' : undefined} />
            </svg>
            <span>{tech.name}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .tech-stack__heading {
    margin-bottom: var(--space-6);
  }

  /* Even, aligned grid instead of a ragged flex row that stranded whitespace
     on the right. auto-fill keeps columns balanced across breakpoints. */
  .tech-stack__icons {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: var(--space-5) var(--space-6);
    color: var(--color-muted);
  }

  .tech-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    transition: color 0.2s ease;
  }

  .tech-item:hover {
    color: var(--color-accent);
  }

  .tech-item svg {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .tech-item span {
    font-size: 0.9rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .tech-stack__icons {
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: var(--space-4) var(--space-5);
    }
  }
</style>
