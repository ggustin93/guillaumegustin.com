---
import { Picture } from 'astro:assets';
import Icon from './icons/Icon.astro';
import { heroImage } from '../data/images';
import { ui, type Lang } from '../i18n/ui';
import type { ShowcaseData } from '../data/types';

interface Props {
  lang: Lang;
  data: ShowcaseData;
}

const { lang, data } = Astro.props;
const t = ui[lang];
---

<section class="hero" aria-label={t.heroAriaLabel}>
  <div class="container-site hero__grid animate-hero">
    <div class="hero__identity">
      <div class="hero__portrait">
        <Picture
          src={heroImage}
          formats={['avif']}
          fallbackFormat="webp"
          widths={[200, 400]}
          sizes="200px"
          alt="Guillaume Gustin, solutions architect and software engineer in Brussels"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <h1 class="hero__name">Guillaume Gustin</h1>
      <p class="hero__positioning">{data.title} <span>{data.subtitle}</span></p>
      <p class="hero__location">{data.location}</p>
      <p class="hero__intro lead">{data.description}</p>
    </div>

    <nav class="hero__links" aria-label={t.heroLinksAriaLabel}>
      <ul>
        {
          data.links.map((link, i) => (
            <li>
              <a
                class:list={['hero__link', { 'is-primary': link.primary }]}
                href={link.url}
                {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                <span class="hero__link-index">{String(i + 1).padStart(2, '0')}</span>
                <Icon name={link.icon} size={18} class="hero__link-icon" />
                <span class="hero__link-label">{link.label}</span>
                <Icon name="arrow-up-right" size={16} class="hero__link-arrow" />
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</section>

<style>
  .hero {
    /* Portrait size + gap are tokens so the link hub can offset itself by the
       exact same amount to share a top grid line with the name. --row-pad-y is
       the link rows' vertical padding, reused in the offset maths below. */
    --portrait-size: 160px;
    --portrait-gap: 28px;
    --row-pad-y: 22px;
    padding-top: clamp(88px, 14vh, 200px);
    padding-bottom: clamp(48px, 8vh, 96px);
  }

  .hero__grid {
    display: grid;
    gap: clamp(40px, 6vw, 80px);
    align-items: start;
  }

  /* Identity column */
  .hero__portrait {
    width: var(--portrait-size);
    aspect-ratio: 1;
    border-radius: 9999px;
    overflow: hidden;
    margin-bottom: var(--portrait-gap);
    background-color: var(--color-card-bg);
    /* Quiet at rest; a thin brand-red ring blooms in on hover alongside the
       colour reveal, so the photo earns its accent through interaction rather
       than carrying a second permanent red against the title. */
    box-shadow: 0 0 0 0 var(--color-accent);
    transition: box-shadow 0.4s ease;
  }

  .hero__portrait:hover {
    box-shadow: 0 0 0 3px var(--color-accent);
  }

  /* Grayscale at rest, reveals colour on hover — same treatment as the About
     portrait. Needs the colour source (gustin-profile.avif) to actually shift. */
  .hero__portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: filter 0.5s ease;
  }

  .hero__portrait:hover :global(img) {
    filter: grayscale(0);
  }

  /* Name sits a tier below the display scale so it frames the role rather than
     shouting over it — the title is the headline here, not the name. */
  .hero__name {
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 300;
    line-height: var(--leading-tight);
    letter-spacing: -0.03em;
    margin-bottom: 10px;
  }

  /* The role is the thesis of the hero — heavy, and carrying the one brand-red
     accent (the exact logo red) on the primary role. Sized to sit on a single
     line at desktop widths; secondary role stays muted. text-wrap: balance keeps
     it tidy if a long localisation does wrap on a narrow column. */
  .hero__positioning {
    font-family: var(--font-mono);
    font-size: clamp(1.0rem, 3.8vw, 1.4rem);
    font-weight: 500;
    color: var(--color-accent);
    line-height: 1.3;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .hero__positioning span {
    font-weight: 500;
    color: var(--color-muted);
  }

  .hero__location {
    margin-top: 6px;
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .hero__intro {
    margin-top: 24px;
    max-width: 48ch;
  }

  /* Link-hub column — numbered rows each closed by a hairline below. No top
     rule: the first row (LinkedIn) is the top element so it lines up cleanly
     with the name instead of a floating hairline sitting above the headline. */
  .hero__links ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hero__link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: var(--row-pad-y) 8px;
    min-height: 48px;
    border-bottom: 1px solid var(--color-border-section);
    color: var(--color-ink);
    text-decoration: none;
    transition:
      color 0.2s cubic-bezier(0.645, 0.045, 0.355, 1),
      padding-left 0.2s cubic-bezier(0.645, 0.045, 0.355, 1);
  }

  .hero__link-index {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.75rem;
    color: var(--color-muted);
    transition: color 0.2s ease;
  }

  .hero__link-icon {
    color: var(--color-muted);
    flex-shrink: 0;
    transition: color 0.2s ease;
  }

  .hero__link-label {
    flex: 1;
    font-size: 1.0625rem;
    font-weight: 500;
  }

  .hero__link.is-primary .hero__link-label {
    font-weight: 600;
  }

  .hero__link-arrow {
    color: var(--color-border-section);
    transition:
      color 0.2s ease,
      transform 0.2s cubic-bezier(0.645, 0.045, 0.355, 1);
  }

  .hero__link:hover,
  .hero__link:focus-visible {
    color: var(--color-accent-strong);
    padding-left: 12px;
  }

  .hero__link:hover .hero__link-index,
  .hero__link:hover .hero__link-icon,
  .hero__link:focus-visible .hero__link-index,
  .hero__link:focus-visible .hero__link-icon {
    color: var(--color-accent-strong);
  }

  .hero__link:hover .hero__link-arrow,
  .hero__link:focus-visible .hero__link-arrow {
    color: var(--color-accent-strong);
    transform: translate(2px, -2px);
  }

  @media (min-width: 860px) {
    .hero {
      --portrait-size: 200px;
    }

    .hero__grid {
      /* Identity column is wider so the (longer, French) role title has room to
         stay on one line; the link hub keeps plenty of width for its rows. */
      grid-template-columns: 1.35fr 1fr;
    }

    /* Align the first link row's text with the name instead of floating the hub
       in dead-centre. Offset = portrait height + gap (lands the row's top at the
       name's line box) minus the row's own top padding (so the LinkedIn text,
       not the row's invisible top edge, sits on the name's line). The portrait
       overhangs above this shared line as a deliberate editorial device. */
    .hero__links {
      padding-top: calc(
        var(--portrait-size) + var(--portrait-gap) - var(--row-pad-y)
      );
    }
  }
</style>
