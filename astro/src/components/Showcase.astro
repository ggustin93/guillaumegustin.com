---
import { Picture } from 'astro:assets';
import Icon from './icons/Icon.astro';
import { heroImage } from '../data/images';
import { ui, type Lang } from '../i18n/ui';
import type { ShowcaseData } from '../data/types';

interface Props {
  lang: Lang;
  data: ShowcaseData;
}

const { lang, data } = Astro.props;
const t = ui[lang];
---

<section class="hero" aria-label={t.heroAriaLabel}>
  <div class="container-site hero__grid animate-hero">
    <div class="hero__identity">
      <div class="hero__portrait">
        <Picture
          src={heroImage}
          formats={['avif']}
          fallbackFormat="webp"
          widths={[200, 400]}
          sizes="200px"
          alt="Guillaume Gustin, solutions architect and software engineer in Brussels"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <h1 class="hero__name">Guillaume Gustin</h1>
      <p class="hero__positioning">{data.title} <span>{data.subtitle}</span></p>
      <p class="hero__location">{data.location}</p>
      <p class="hero__intro lead">{data.description}</p>
    </div>

    <nav class="hero__links" aria-label={t.heroLinksAriaLabel}>
      <ul>
        {
          data.links.map((link, i) => (
            <li>
              <a
                class:list={['hero__link', { 'is-primary': link.primary }]}
                href={link.url}
                {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                <span class="hero__link-index">{String(i + 1).padStart(2, '0')}</span>
                <Icon name={link.icon} size={18} class="hero__link-icon" />
                <span class="hero__link-label">{link.label}</span>
                <Icon name="arrow-up-right" size={16} class="hero__link-arrow" />
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(120px, 18vh, 200px);
    padding-bottom: clamp(48px, 8vh, 96px);
  }

  .hero__grid {
    display: grid;
    gap: clamp(40px, 6vw, 80px);
    align-items: start;
  }

  /* Identity column */
  .hero__portrait {
    width: 160px;
    aspect-ratio: 1;
    border-radius: 9999px;
    overflow: hidden;
    margin-bottom: 28px;
    background-color: var(--color-card-bg);
  }

  /* Grayscale at rest, reveals colour on hover — same treatment as the About
     portrait. Needs the colour source (gustin-profile.avif) to actually shift. */
  .hero__portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: filter 0.5s ease;
  }

  .hero__portrait:hover :global(img) {
    filter: grayscale(0);
  }

  .hero__name {
    font-size: var(--text-display);
    font-weight: 300;
    line-height: var(--leading-tight);
    letter-spacing: -0.03em;
    margin-bottom: 18px;
  }

  .hero__positioning {
    font-size: clamp(1.05rem, 2vw, 1.4rem);
    font-weight: 400;
    color: var(--color-body);
    line-height: 1.3;
  }

  .hero__positioning span {
    color: var(--color-muted);
  }

  .hero__location {
    margin-top: 6px;
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .hero__intro {
    margin-top: 24px;
    max-width: 48ch;
  }

  /* Link-hub column — numbered rows separated by hairlines */
  .hero__links ul {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-border-section);
  }

  .hero__link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 4px;
    border-bottom: 1px solid var(--color-border-section);
    color: var(--color-ink);
    text-decoration: none;
    transition:
      color 0.2s cubic-bezier(0.645, 0.045, 0.355, 1),
      padding-left 0.2s cubic-bezier(0.645, 0.045, 0.355, 1);
  }

  .hero__link-index {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.75rem;
    color: var(--color-muted);
    transition: color 0.2s ease;
  }

  .hero__link-icon {
    color: var(--color-muted);
    flex-shrink: 0;
    transition: color 0.2s ease;
  }

  .hero__link-label {
    flex: 1;
    font-size: 1.0625rem;
    font-weight: 500;
  }

  .hero__link.is-primary .hero__link-label {
    font-weight: 600;
  }

  .hero__link-arrow {
    color: var(--color-border-section);
    transition:
      color 0.2s ease,
      transform 0.2s cubic-bezier(0.645, 0.045, 0.355, 1);
  }

  .hero__link:hover,
  .hero__link:focus-visible {
    color: var(--color-accent-strong);
    padding-left: 12px;
  }

  .hero__link:hover .hero__link-index,
  .hero__link:hover .hero__link-icon,
  .hero__link:focus-visible .hero__link-index,
  .hero__link:focus-visible .hero__link-icon {
    color: var(--color-accent-strong);
  }

  .hero__link:hover .hero__link-arrow,
  .hero__link:focus-visible .hero__link-arrow {
    color: var(--color-accent-strong);
    transform: translate(2px, -2px);
  }

  @media (min-width: 860px) {
    .hero__grid {
      grid-template-columns: 1.1fr 1fr;
    }

    .hero__portrait {
      width: 200px;
    }

    /* The identity column is much taller than the 4-row link hub. Top-aligning
       both left a large dead gap below the links, making the right column look
       like it floated. Centre the link block against the identity column so the
       hero reads as a deliberately balanced two-column composition. */
    .hero__links {
      align-self: center;
    }
  }
</style>
