---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={isStroked ? 'none' : 'currentColor'}
  stroke={isStroked ? 'currentColor' : 'none'}
  stroke-width={isStroked ? 2 : undefined}
  stroke-linecap={isStroked ? 'round' : undefined}
  stroke-linejoin={isStroked ? 'round' : undefined}
  class={className}
  aria-hidden="true"
  set:html={paths[name]}
/>
