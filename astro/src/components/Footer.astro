---
import { ui, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  copyright: string;
  carbonText: string;
  nav: { label: string; href: string }[];
}

const { lang, copyright, carbonText, nav } = Astro.props;
const t = ui[lang];
---

<footer class="footer" role="contentinfo">
  <div class="container-site footer__inner">
    <div class="footer__copy">{copyright}</div>
    <nav class="footer__links" aria-label={t.footerNavAriaLabel}>
      <ul>
        {
          nav.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
    <a
      href="https://kastor.green/simple-audit-result/d7b69a1b-5e5c-42eb-ee56-08ded0abd855"
      target="_blank"
      rel="noopener noreferrer"
      class="footer__carbon"
    >
      <span aria-hidden="true">🌱</span>
      {carbonText}
    </a>
  </div>
</footer>

<style>
  .footer {
    padding-block: var(--space-8);
    background-color: var(--color-dark-panel);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .footer__inner {
      flex-direction: row;
      justify-content: space-between;
      gap: 0;
    }
  }

  .footer__copy {
    color: rgba(255, 255, 255, 0.6);
    white-space: nowrap;
    font-size: 12px;
    font-weight: 300;
  }

  .footer__links ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__links a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    font-size: 14px;
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    padding: 0 12px;
  }

  .footer__links a:hover {
    text-decoration: underline;
  }

  .footer__carbon {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    min-height: 44px;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.3s ease;
  }

  .footer__carbon:hover {
    color: #fff;
  }
</style>
