---
import '../styles/global.css';
import JsonLd from '../components/seo/JsonLd.astro';
import { ui, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  description: string;
}

const { lang, title, description } = Astro.props;
const t = ui[lang];

const siteUrl = Astro.site!.href; // https://guillaumegustin.be/
// Root keeps its trailing slash (normalized form); subpaths match Firebase's
// trailingSlash:false canonicalization (/fr, not /fr/).
const canonical =
  Astro.url.pathname === '/' ? siteUrl : new URL(Astro.url.pathname, Astro.site).href.replace(/\/$/, '');
const ogImageUrl = new URL('/img/who-am-i/og-card.jpg', Astro.site).href;
const ogLocale = lang === 'fr' ? 'fr_BE' : 'en_US';
const ogLocaleAlternate = lang === 'fr' ? 'en_US' : 'fr_BE';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Guillaume Gustin" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <!-- Hreflang for multilingual SEO -->
    <link rel="alternate" hreflang="en" href={siteUrl} />
    <link rel="alternate" hreflang="fr" href={new URL('/fr', Astro.site).href} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Guillaume Gustin — Solutions Architect & Software Engineer based in Brussels" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:site_name" content="Guillaume Gustin" />

    <!-- Twitter Card — 1200×630 branded social card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Guillaume Gustin — Solutions Architect & Software Engineer based in Brussels" />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#d6452c" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/inter/Inter-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter/Inter-SemiBold.woff2" as="font" type="font/woff2" crossorigin />

    <JsonLd lang={lang} title={title} description={description} ogImageUrl={ogImageUrl} />

    <!-- Umami Analytics (privacy-focused) -->
    <script
      is:inline
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="ef9ecdfc-e05f-4030-b00f-dfc46675b6de"></script>

    <script is:inline>
      // Marks JS availability so scroll-reveal styles only apply when they can run.
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">{t.skipLink}</a>
    <slot />
    <script src="../scripts/main.ts"></script>
  </body>
</html>
